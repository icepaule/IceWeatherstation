diff --git a/tasmota/tasmota_xsns_sensor/xsns_01_counter.ino b/tasmota/tasmota_xsns_sensor/xsns_01_counter.ino
index 7a3c559..8e09bb7 100644
--- a/tasmota/tasmota_xsns_sensor/xsns_01_counter.ino
+++ b/tasmota/tasmota_xsns_sensor/xsns_01_counter.ino
@@ -237,8 +237,18 @@ void CounterShow(bool json)
         }
 #ifdef USE_WEBSERVER
       } else {
-        WSContentSend_PD(PSTR("{s}" D_COUNTER " %d{m}%s%s{e}"),
-          i +1, counter, (bitRead(Settings->pulse_counter_type, i)) ? " " D_UNIT_SECOND : "");
+        // IceWeatherstation: sprechende Labels statt "Counter 1"/"Counter 2"
+        // fuer die beiden fest verdrahteten Kanaele dieses Projekts.
+        if (0 == i) {
+          WSContentSend_PD(PSTR("{s}Regenmesser (Kippen){m}%s%s{e}"),
+            counter, (bitRead(Settings->pulse_counter_type, i)) ? " " D_UNIT_SECOND : "");
+        } else if (1 == i) {
+          WSContentSend_PD(PSTR("{s}Anemometer (Pulse){m}%s%s{e}"),
+            counter, (bitRead(Settings->pulse_counter_type, i)) ? " " D_UNIT_SECOND : "");
+        } else {
+          WSContentSend_PD(PSTR("{s}" D_COUNTER " %d{m}%s%s{e}"),
+            i +1, counter, (bitRead(Settings->pulse_counter_type, i)) ? " " D_UNIT_SECOND : "");
+        }
 #endif  // USE_WEBSERVER
       }
     }
diff --git a/tasmota/tasmota_xsns_sensor/xsns_02_analog.ino b/tasmota/tasmota_xsns_sensor/xsns_02_analog.ino
index 89a2cfe..8723dfc 100644
