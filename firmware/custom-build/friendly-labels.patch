+              WSContentSend_PD(PSTR("{s}Windfahne (roh){m}%d{e}"), analog);
+            } else {
+              WSContentSend_PD(HTTP_SNS_ANALOG, "", type_index + offset, analog);
+            }
 #endif  // USE_WEBSERVER
           }
 #ifdef USE_LIGHT
@@ -876,7 +882,13 @@ void AdcShow(bool json) {
           ResponseAppend_P(PSTR("\"" D_JSON_RANGE "%s\":%s"), adc_channel, range_chr);
 #ifdef USE_WEBSERVER
         } else {
-          WSContentSend_PD(HTTP_SNS_RANGE_CHR, adc_name, range_chr);
+          // IceWeatherstation: "Schallpegel (roh)" statt "ADC1 Range" fuer
+          // den einzigen ADC-Range-Kanal dieses Projekts (GPIO35, SEN0232).
+          if (0 == strcmp(adc_name, "ADC1")) {
+            WSContentSend_PD(PSTR("{s}Schallpegel (roh){m}%s{e}"), range_chr);
+          } else {
+            WSContentSend_PD(HTTP_SNS_RANGE_CHR, adc_name, range_chr);
+          }
 #endif  // USE_WEBSERVER
         }
         break;
